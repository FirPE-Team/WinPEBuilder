_SUB 判断是否存在无线网卡
  CALC 超时计数=0
  LOOP #1=1,
  {*
    ADSL-wlan 0,,query,无线网卡
    FIND $%无线网卡%!=,  // 检测到无线网卡存在
    {*
      MSTR* 是否连接=<3>%无线网卡%
      FIND $%是否连接%!=1,  // 状态字段未连接
      {*
        TEAM WAIT 3000|开始连接|EXIT LOOP
      }
      ELSE  // 已连接状态
      {*
        EXIT LOOP
      }
    }
    CALC 超时计数=%超时计数%+2
    IFEX $%超时计数%>=300, EXIT LOOP
    WAIT 2000
  }
_END

_SUB 开始连接
  EXEC =!"%Curdir%\AutoWIFI.exe" -a
_END

判断是否存在无线网卡
